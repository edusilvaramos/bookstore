{% extends 'base.html.twig' %}

{% block title %}My Cart{% endblock %}

{% block body %}
<div class="container py-4">
    <h2 class="mb-4">My Cart</h2>

    <turbo-frame id="cart_frame">
    {% if items is not empty %}
        <div class="card bg-dark">
            <div class="card-body">
                {% for item in items %}
                    {% set book = item.book %}
                    <div class="d-flex align-items-center mb-3 border-bottom pb-3">
                        <img
                            src="{{ book.coverUrl }}"
                            alt="{{ book.title }}"
                            style="width: 80px; height: 100px; object-fit: cover;"
                            class="me-3 rounded"
                        >

                        <div class="flex-grow-1">
                            <h6 class="mb-1">{{ book.title }}</h6>
                            <small class="text-muted">{{ book.authors|join(', ') }}</small>
                        </div>

                        <div class="text-end">
                            <div class="d-inline-flex align-items-center gap-2">
                                <a
                                    href="{{ path('app_cart_decrease', {id: book.id}) }}"
                                    class="btn btn-sm btn-outline-light"
                                    data-turbo-frame="cart_frame"
                                    aria-label="Decrease quantity"
                                >
                                    -
                                </a>

                                <span>Qty: {{ item.quantity }}</span>

                                <form method="post" action="{{ path('app_cart_add', {id: book.id}) }}" class="d-inline" data-turbo-frame="cart_frame">
                                    <input type="hidden" name="from" value="cart">
                                    <input type="hidden" name="_token" value="{{ csrf_token('add_to_cart_' ~ book.id) }}">
                                    <button
                                        type="submit"
                                        class="btn btn-sm btn-outline-light"
                                        aria-label="Increase quantity"
                                    >
                                        +
                                    </button>
                                </form>
                            </div>

                            <div class="fw-bold">
                                {{ (book.price * item.quantity)|euro }}
                            </div>

                            <a
                                href="{{ path('app_cart_remove', {id: book.id}) }}"
                                class="btn btn-sm btn-outline-danger mt-2"
                                data-turbo-frame="cart_frame"
                            >
                                Remove
                            </a>
                        </div>
                    </div>
                {% endfor %}

                {% if addresses is not empty %}
                    <form method="get" class="mb-3" data-turbo-frame="cart_frame">
                        <div class="mb-2">
                            <label for="address_id" class="form-label">Delivery address:</label>
                            <select name="address_id" id="address_id" class="form-select" onchange="this.form.submit()">
                                {% for address in addresses %}
                                    <option value="{{ address.id }}" {% if selectedAddress and address.id == selectedAddress.id %}selected{% endif %}>
                                        {{ address.label }} - {{ addressLabels[address.id]|default('Incomplete address') }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                    </form>
                {% endif %}

                {% if shippingError %}
                    <div class="alert alert-warning py-2" role="alert">
                        {{ shippingError }}
                    </div>
                {% endif %}

                {% if distanceKm is not null %}
                    <div class="d-flex justify-content-between align-items-center">
                        <span>Estimated distance:</span>
                        <span>{{ distanceKm }} km</span>
                    </div>
                {% endif %}

                {% if shippingCost is not null %}
                    <div class="d-flex justify-content-between align-items-center">
                        <span>Estimated shipping:</span>
                        <span>{{ shippingCost|euro }}</span>
                    </div>

                    <small class="text-muted d-block mt-1">
                        Shipping is estimated and may be updated at checkout.
                    </small>
                {% endif %}

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <h5>Subtotal:</h5>
                    <h5 class="fw-bold">{{ totalPrice|euro }}</h5>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-2">
                    <h4>Estimated total:</h4>
                    <h4 class="fw-bold">{{ grandTotal|euro }}</h4>
                </div>

                <div class="mt-3 text-end">
                    <a href="#" class="btn btn-primary">
                        Checkout
                    </a>
                </div>
            </div>
        </div>
    {% else %}
        <div class="alert alert-secondary">
            Your cart is empty.
        </div>
    {% endif %}
    </turbo-frame>
</div>
{% endblock %}