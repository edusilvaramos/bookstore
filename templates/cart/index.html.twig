{% extends 'base.html.twig' %}

{% block title %}Cart index
{% endblock %}

{% block body %}
	<h1>Your Cart</h1>

	<div class="row row-cols-1 row-cols-md-3 row-cols-lg-5 g-3">
		{% for book in books %}
			<div class="col">
				<div class="card h-100">
					<div class="card-body d-flex flex-column">
						{% set coverUrl = book.coverUrl %}
						{% if coverUrl and ('photo-1455885666463-5a5f2567c7b2' in coverUrl or 'photo-1473862170182-6fcb6d49f4c4' in coverUrl) %}
							{% set coverUrl = 'https://images.unsplash.com/photo-1512820790803-83ca734da794' %}
						{% endif %}
						<a class="btn btn-sm btn-outline-secondary border-0 " href="{{ path('app_home_show', {'id': book.id}) }}">

							{% if coverUrl %}
								<img src="{{ coverUrl }}" class="book-cover-media rounded mb-3" alt="Cover of {{ book.title }}">
							{% else %}
								<div class="bg-light text-muted rounded p-4 text-center mb-3 book-cover-placeholder">No image</div>
							{% endif %}
						</a>

						<a href="{{ path('app_home_show', {'id': book.id}) }}">
							<h5 class="card-title mt-3">{{ book.title }}</h5>
						</a>
						<h6 class="card-subtitle mb-3 text-muted">{{ book.authors ? book.authors|join(', ') : 'Unknown author' }}</h6>
						{% set priceRaw = book.price ~ '' %}
						<p>Price:
							{{ priceRaw|slice(0, -2) }},{{ priceRaw|slice(-2) }}
							€</p>

						{# button add to cart #}
						<div class="mt-auto d-flex justify-content-center">
							<a type="button" href="{{ path('app_cart_remove', {'id': book.id}) }}" class="btn btn-light">Remove from cart</a>
						</div>
					</div>
				</div>
			</div>
		{% endfor %}
	</div>
{% endblock %}
