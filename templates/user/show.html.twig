{% extends 'base.html.twig' %}

{% block title %}My Account{% endblock %}

{% block body %}
<div class="container py-4">

  <div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="h3 mb-0">My Account</h1>

    <a href="{{ path('app_logout') }}" class="btn btn-sm btn-outline-danger">
      Logout
    </a>
  </div>

  <div class="card bg-dark border-secondary shadow-sm">
    <div class="card-body p-4">

      <div class="d-flex align-items-start justify-content-between gap-3">
        <div>
          <div class="h5 mb-1">
            {{ user.firstName }} {{ user.lastName }}
          </div>
          <div class="text-muted">
            {{ user.email }}
          </div>
        </div>

        <div class="text-end">
          {% if user.isVerified %}
            <span class="badge text-bg-success">Verified</span>
          {% else %}
            <span class="badge text-bg-warning">Not verified</span>
          {% endif %}
        </div>
      </div>

      <hr class="border-secondary my-4">

      <div class="row g-3">

        <div class="col-md-6">
          <div class="text-muted small">Phone</div>
          <div class="fw-semibold">
            {{ user.phone ?: '—' }}
          </div>
        </div>

        <div class="col-md-6">
          <div class="text-muted small">Date of birth</div>
          <div class="fw-semibold">
            {{ user.dateOfBirth ? user.dateOfBirth|date('Y-m-d') : '—' }}
          </div>
        </div>

      </div>

      <div class="d-flex flex-wrap gap-2 mt-4">
          <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-primary">
            Edit profile
          </a>

          <a href="{{ path('app_address_new') }}" class="btn btn-outline-primary">
            Add address
          </a>

          <span class="ms-auto">
            {{ include('user/_delete_form.html.twig') }}
          </span>
        </div>

    </div>
  </div>

  <div class="mt-4">
    <h2 class="h5 mb-3">Addresses</h2>

    <div class="row g-3">
      {% for address in user.addresses %}
        <div class="col-12 col-md-6 col-lg-4">
          <div class="card h-100">
            <div class="card-body">
              <div class="fw-semibold mb-1">{{ address.label }}</div>
              <div class="text-muted small">{{ address.streetLine1 }}{% if address.streetLine2 %}, {{ address.streetLine2 }}{% endif %}</div>
              <div class="text-muted small">{{ address.city }}, {{ address.stateOrRegion }} {{ address.postalCode }}</div>
              <div class="text-muted small">{{ address.countryCode }}</div>
              {% if address.additionalInfo %}
                <div class="mt-2 small">{{ address.additionalInfo }}</div>
              {% endif %}
            </div>

            <div class="card-footer bg-transparent border-0 d-flex gap-2">
              <a href="{{ path('app_address_edit', {'id': address.id}) }}" class="btn ">Edit</a>
              {{ include('address/_delete_form.html.twig', {address: address}) }}
            </div>
          </div>
        </div>
      {% else %}
        <div class="col-12">
          <div class="text-muted">You don't have any saved addresses yet.</div>
        </div>
      {% endfor %}
    </div>
  </div>

</div>
{% endblock %}