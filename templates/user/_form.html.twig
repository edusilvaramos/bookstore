{{ form_start(form, { attr: { class: 'needs-validation', novalidate: 'novalidate' } }) }}

{% if form.vars.submitted and not form.vars.valid %}
    <div class="alert alert-danger mb-3" role="alert">
        <strong>Please fix the errors highlighted below.</strong>
        {% if form.vars.errors|length > 0 %}
            <ul class="mb-0 mt-1 ps-3">
                {% for error in form.vars.errors %}<li>{{ error.message }}</li>{% endfor %}
            </ul>
        {% endif %}
    </div>
{% endif %}

<div class="card bg-dark border-secondary shadow-sm mb-4">
  <div class="card-body p-4 ">

    <div class="row g-3">

      <div class="col-12">
        {{ form_label(form.email, null, { label_attr: { class: 'form-label' } }) }}
        {{ form_widget(form.email, { attr: { class: 'form-control' } }) }}
        {{ form_errors(form.email) }}
      </div>

      <div class="col-md-6">
        {{ form_label(form.firstName, 'First name', { label_attr: { class: 'form-label' } }) }}
        {{ form_widget(form.firstName, { attr: { class: 'form-control' } }) }}
        {{ form_errors(form.firstName) }}
      </div>

      <div class="col-md-6">
        {{ form_label(form.lastName, 'Last name', { label_attr: { class: 'form-label' } }) }}
        {{ form_widget(form.lastName, { attr: { class: 'form-control' } }) }}
        {{ form_errors(form.lastName) }}
      </div>

      <div class="col-md-6">
        {{ form_label(form.phone, null, { label_attr: { class: 'form-label' } }) }}
        {{ form_widget(form.phone, { attr: { class: 'form-control' } }) }}
        {{ form_errors(form.phone) }}
      </div>

      <div class="col-md-6">
        {{ form_label(form.dateOfBirth, 'Date of birth', { label_attr: { class: 'form-label' } }) }}
        {{ form_widget(form.dateOfBirth, { attr: { class: 'form-control' } }) }}
        {{ form_errors(form.dateOfBirth) }}
      </div>
    </div>

    <div class="d-flex gap-2 mt-4">
      <button class="btn btn-primary">
        {{ button_label|default('Save') }}
      </button>

      <a href="{{ path('app_user_show', {id: user.id}) }}" class="btn btn-outline-light">
        Cancel
      </a>
    </div>

  </div>
</div>

{{ form_end(form) }}