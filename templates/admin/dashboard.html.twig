{% extends '@EasyAdmin/layout.html.twig' %}

{% block content_title %}Admin Dashboard{% endblock %}

{% block main %}
    <div class="row g-3">
        <div class="col-12 col-md-6 col-lg-4">
            <a class="card text-decoration-none" href="{{ ea_url().setController('App\\Controller\\Admin\\BookCrudController').generateUrl() }}">
                <div class="card-body">
                    <h5 class="card-title mb-1">Books</h5>
                    <p class="card-text text-muted mb-0">Manage your catalog</p>
                </div>
            </a>
        </div>

        <div class="col-12 col-md-6 col-lg-4">
            <a class="card text-decoration-none" href="{{ ea_url().setController('App\\Controller\\Admin\\UserCrudController').generateUrl() }}">
                <div class="card-body">
                    <h5 class="card-title mb-1">Users</h5>
                    <p class="card-text text-muted mb-0">Manage accounts & roles</p>
                </div>
            </a>
        </div>
    </div>
{% endblock %}