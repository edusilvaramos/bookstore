{% extends 'base.html.twig' %}

{% block title %}Log in
{% endblock %}

{% block body %}
<div class="container w-50 mt-5">
	<form method="post">
		{% if error %}
			<div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
		{% endif %}

		<h1 class="h3 mb-3 font-weight-normal">Please sign in</h1>
		<label for="username">Email</label>
		<input type="email" value="{{ last_username }}" name="email" id="username" class="form-control" autocomplete="email" required autofocus>
		<label for="password">Password</label>
		<input type="password" name="password" id="password" class="form-control" autocomplete="current-password" required>
		<div>
			<label>
				<input type="checkbox" name="_remember_me" checked>
				Remember me
			</label>
		</div>
        

		<input
		type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

		<button class="btn btn-lg btn-primary" type="submit">
			Sign in
		</button>
		<div class="mt-3">
			<a href="{{ path('app_forgot_password_request') }}">Forgot password?</a>
		</div>
		<div class="mt-2">
			Don't have an account?
			<a href="{{ path('app_register') }}">Create account</a>
		</div>
	</form>
</div>
{% endblock %}
