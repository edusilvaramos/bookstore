{% set items = books.items ?? [] %}

{% if items is empty %}
	<div class="alert alert-info" role="alert">
		No books found.
	</div>
{% else %}
	<div class="row row-cols-5 g-3">
		{% for item in items %}
			<div class="col">
				{% include 'home/cardBook.html.twig' with { book: item } only %}
			</div>
		{% endfor %}
	</div>
{% endif %}
