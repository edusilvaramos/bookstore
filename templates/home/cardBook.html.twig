<div class="card h-100">
  <div class="card-body d-flex flex-column">
     {% if thumbnail %}
      <img src="{{ thumbnail }}" class="book-cover-media rounded mb-3" alt="Cover of {{ title }}">
    {% else %}
      <div class="bg-light text-muted rounded p-4 text-center mb-3 book-cover-placeholder">No image</div>
    {% endif %}
    <h5 class="card-title">{{ title }}</h5>
    <h6 class="card-subtitle mb-3 text-muted">{{ authorsText }}</h6>
  </div>
</div>
