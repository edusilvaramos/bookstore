{% extends 'base.html.twig' %}

{% block title %}Create your account
{% endblock %}

{% block body %}
	<div class="container py-5">
		<div class="row justify-content-center">
			<div class="col-12 col-md-10 col-lg-8 col-xl-7">
				<div class="card shadow border-0">
					<div
						class="card-body p-4 p-md-5">
						{# Header with better visual hierarchy #}
						<div class="text-center mb-4">
							<h1 class="h2 mb-2">Create your account</h1>
							<p class="text-secondary">Join us to start shopping and enjoy exclusive benefits</p>
						</div>

						{{ form_start(registrationForm, { 
                            attr: { 
                                novalidate: 'novalidate', 
                                'data-turbo': 'false',
                                class: 'needs-validation' <
                            } 
                        }) }}

						{# Form fields organized in logical groups #}
						<div
							class="row g-4">
							{# Email - full width as it's most important #}
							<div class="col-12">
								<div class="form-group">
									{{ form_label(registrationForm.email, 'Email address', {
                                        label_attr: { class: 'form-label fw-semibold' }
                                    }) }}
									{{ form_widget(registrationForm.email, {
                                        attr: { 
                                            class: 'form-control form-control-lg',
                                            placeholder: 'your@email.com',
                                            autocomplete: 'email'
                                        }
                                    }) }}
									{{ form_errors(registrationForm.email, { attr: { class: 'invalid-feedback d-block' } }) }}
									<div class="form-text">We'll never share your email with anyone else.</div>
								</div>
							</div>

							{# Name fields side by side on larger screens #}
							<div class="col-12 col-md-6">
								<div class="form-group">
									{{ form_label(registrationForm.firstName, 'First name', {
                                        label_attr: { class: 'form-label fw-semibold' }
                                    }) }}
									{{ form_widget(registrationForm.firstName, {
                                        attr: { 
                                            class: 'form-control form-control-lg',
                                            placeholder: 'John',
                                            autocomplete: 'given-name'
                                        }
                                    }) }}
									{{ form_errors(registrationForm.firstName, { attr: { class: 'invalid-feedback d-block' } }) }}
								</div>
							</div>
							<div class="col-12 col-md-6">
								<div class="form-group">
									{{ form_label(registrationForm.lastName, 'Last name', {
                                        label_attr: { class: 'form-label fw-semibold' }
                                    }) }}
									{{ form_widget(registrationForm.lastName, {
                                        attr: { 
                                            class: 'form-control form-control-lg',
                                            placeholder: 'Doe',
                                            autocomplete: 'family-name'
                                        }
                                    }) }}
									{{ form_errors(registrationForm.lastName, { attr: { class: 'invalid-feedback d-block' } }) }}
								</div>
							</div>

							{# Contact details group #}
							<div class="col-12 col-md-6">
								<div class="form-group">
									{{ form_label(registrationForm.phone, 'Phone number', {
                                        label_attr: { class: 'form-label fw-semibold' }
                                    }) }}
									{{ form_widget(registrationForm.phone, {
                                        attr: { 
                                            class: 'form-control form-control-lg',
                                            placeholder: '+1 (555) 000-9999',
                                            autocomplete: 'tel'
                                        }
                                    }) }}
									{{ form_errors(registrationForm.phone, { attr: { class: 'invalid-feedback d-block' } }) }}
								</div>
							</div>
							<div class="col-12 col-md-6">
								<div class="form-group">
									{{ form_label(registrationForm.dateOfBirth, 'Date of birth', {
                                        label_attr: { class: 'form-label fw-semibold' }
                                    }) }}
									{{ form_widget(registrationForm.dateOfBirth, {
                                        attr: { 
                                            class: 'form-control form-control-lg',
                                            placeholder: 'MM/DD/YYYY',
                                            autocomplete: 'bday'
                                        }
                                    }) }}
									{{ form_errors(registrationForm.dateOfBirth, { attr: { class: 'invalid-feedback d-block' } }) }}
								</div>
							</div>

							{# Password with strength indicator #}
							<div class="col-12">
								<div class="form-group">
									{{ form_label(registrationForm.plainPassword, 'Password', {
                                        label_attr: { class: 'form-label fw-semibold' }
                                    }) }}
									{{ form_widget(registrationForm.plainPassword, {
                                        attr: { 
                                            class: 'form-control form-control-lg',
                                            placeholder: 'Create a strong password',
                                            autocomplete: 'new-password'
                                        }
                                    }) }}
									{{ form_errors(registrationForm.plainPassword, { attr: { class: 'invalid-feedback d-block' } }) }}

									{# Password requirements helper #}
									<div class="password-requirements mt-2 small text-secondary">
										<div class="mb-1">Password must contain:</div>
										<ul class="list-unstyled ps-2">
											<li class="mb-1">✓ At least 8 characters</li>
											<li class="mb-1">✓ At least one uppercase letter</li>
											<li class="mb-1">✓ At least one number</li>
											<li class="mb-1">✓ At least one special character</li>
										</ul>
									</div>
								</div>
							</div>
						</div>
						<div class="d-grid gap-2 mt-4">
							<button type="submit" class="btn btn-primary btn-lg py-3" id="registerBtn">
								<span class="spinner-border spinner-border-sm d-none me-2" role="status" aria-hidden="true"></span>
								Create my account
							</button>
						</div>

						{{ form_end(registrationForm) }}

						{# Login link with better styling #}
						<div class="text-center mt-4 pt-3 border-top">
							<p class="mb-0">
								Already have an account?
								<a href="{{ path('app_login') }}" class="fw-semibold text-decoration-none">
									Sign in here
								</a>
							</p>
						</div>

					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
