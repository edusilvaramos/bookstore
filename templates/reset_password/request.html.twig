{% extends 'base.html.twig' %}

{% block title %}Reset your password{% endblock %}

{% block body %}
<div class="row justify-content-center my-5">
    <div class="col-12 col-md-10 col-lg-7 col-xl-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-md-5">
                {% for flash_error in app.flashes('reset_password_error') %}
                    <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
                {% endfor %}

                <h1 class="h3 mb-2">Reset your password</h1>
                <p class="text-muted mb-4">Enter your account email and we will send you a reset link.</p>

                {{ form_start(requestForm, { attr: { novalidate: 'novalidate' } }) }}
                    {{ form_row(requestForm.email) }}
                    <div class="d-grid mt-3">
                        <button class="btn btn-primary">Send reset email</button>
                    </div>
                {{ form_end(requestForm) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
