{% extends 'base.html.twig' %}

{% block title %}Book index{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0">Book index</h1>
            <a class="btn btn-primary" href="{{ path('app_home_new') }}">Create new</a>
        </div>

        {% if books is empty %}
            <div class="alert alert-info" role="alert">
                No books found.
            </div>
        {% else %}
            <div class="row row-cols-1 row-cols-md-3 row-cols-lg-5 g-3">
                {% for book in books %}
                    <div class="col">
                        <div class="card h-100">
                            <div class="card-body d-flex flex-column">
                                {% set coverUrl = book.coverUrl %}
                                {% if coverUrl and ('photo-1455885666463-5a5f2567c7b2' in coverUrl or 'photo-1473862170182-6fcb6d49f4c4' in coverUrl) %}
                                    {% set coverUrl = 'https://images.unsplash.com/photo-1512820790803-83ca734da794' %}
                                {% endif %}

                                {% if coverUrl %}
                                    <img src="{{ coverUrl }}" class="book-cover-media rounded mb-3" alt="Cover of {{ book.title }}">
                                {% else %}
                                    <div class="bg-light text-muted rounded p-4 text-center mb-3 book-cover-placeholder">No image</div>
                                {% endif %}

                                <h5 class="card-title">{{ book.title }}</h5>
                                <h6 class="card-subtitle mb-3 text-muted">{{ book.authors ? book.authors|join(', ') : 'Unknown author' }}</h6>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
