{% extends 'base.html.twig' %}

{% block title %}Bookstore
{% endblock %}

{% block body %}
	<div class="container py-5">

		<div class="text-center mb-5">
			<p class="text-uppercase text-muted small mb-2" style="letter-spacing: 2px;">
				Discover your next read
			</p>
			<h1 class="fw-semibold mb-3">Our Book Collection</h1>
			<p class="text-muted mx-auto" style="max-width: 640px;">
				Explore a curated selection of books, from timeless classics to modern favorites.
			</p>
		</div>

		<form method="get" action="{{ path('app_book_index') }}" class="row g-2 align-items-end justify-content-center mb-4">
			<div class="col-12 col-md-6 col-lg-4">
				<label for="category-filter" class="form-label text-muted small mb-1">Category</label>
				<select id="category-filter" name="category" class="form-select rounded-3">
					<option value="">All categories</option>
					{% for category in categories %}
						<option value="{{ category.id }}" {% if selectedCategoryId == category.id %}selected{% endif %}>{{ category.name }}</option>
					{% endfor %}
				</select>
			</div>
			<div class="col-12 col-md-auto d-grid d-md-flex gap-2">
				<button type="submit" class="btn btn-dark rounded-pill px-4">Filter</button>
				<a href="{{ path('app_book_index') }}" class="btn btn-outline-secondary rounded-pill px-4">Clear</a>
			</div>
		</form>

		{% if selectedCategoryId %}
			<p class="text-center text-muted small mb-4">Showing books from the selected category.</p>
		{% endif %}

		{% if books|length > 0 %}
			<div class="row g-4">
				{% for book in books %}
					<div class="col-12 col-sm-6 col-lg-4 col-xl-3 book-item">
						<div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden book-card">

							<a href="{{ path('app_book_show', {id: book.id}) }}" class="text-decoration-none">
								<div class="bg-light d-flex align-items-center justify-content-center p-3" style="height: 360px;">
									<img src="{{ book.coverUrl }}" class="img-fluid rounded-3" alt="{{ book.title }}" style="max-height: 100%; object-fit: contain;" onerror="this.closest('.book-item')?.remove();">
								</div>
							</a>

							<div class="card-body d-flex flex-column p-4">
								<p class="text-muted small mb-2">
									{{ book.authors|join(', ') }}
								</p>

								<h5 class="card-title fw-semibold mb-2" style="min-height: 48px;">
									{{ book.title }}
								</h5>

								<p class="fw-bold fs-5 mb-4">
									{{ book.price|euro }}
								</p>

								<div class="mt-auto d-grid gap-2">
									<a href="{{ path('app_book_show', {id: book.id}) }}" class="btn btn-outline-dark rounded-pill">
										View details
									</a>

									<form method="post" action="{{ path('app_cart_add', {id: book.id}) }}" class="d-grid">
										<input type="hidden" name="_token" value="{{ csrf_token('add_to_cart_' ~ book.id) }}">
										<button type="submit" class="btn btn-dark rounded-pill">Add to cart</button>
									</form>
								</div>
							</div>

						</div>
					</div>
				{% endfor %}
			</div>
		{% else %}
			<div class="text-center py-5">
				<h2 class="h4 mb-3">No books found</h2>
				<p class="text-muted mb-0">Please check back later for new arrivals.</p>
			</div>
		{% endif %}
	</div>
{% endblock %}
