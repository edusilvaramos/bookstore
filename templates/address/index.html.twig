{% extends 'base.html.twig' %}

{% block title %}Address index{% endblock %}

{% block body %}
    <h1>Address index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Label</th>
                <th>StreetLine1</th>
                <th>StreetLine2</th>
                <th>City</th>
                <th>StateOrRegion</th>
                <th>PostalCode</th>
                <th>CountryCode</th>
                <th>AdditionalInfo</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for address in addresses %}
            <tr>
                <td>{{ address.id }}</td>
                <td>{{ address.label }}</td>
                <td>{{ address.streetLine1 }}</td>
                <td>{{ address.streetLine2 }}</td>
                <td>{{ address.city }}</td>
                <td>{{ address.stateOrRegion }}</td>
                <td>{{ address.postalCode }}</td>
                <td>{{ address.countryCode }}</td>
                <td>{{ address.additionalInfo }}</td>
                <td>
                    <a href="{{ path('app_address_show', {'id': address.id}) }}">show</a>
                    <a href="{{ path('app_address_edit', {'id': address.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="10">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_address_new') }}">Create new</a>
{% endblock %}
