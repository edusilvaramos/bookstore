{{ form_start(form, { attr: { novalidate: 'novalidate' } }) }}
{% if form.vars.submitted and not form.vars.valid %}
    <div class="alert alert-danger mb-3" role="alert">
        <strong>Please fix the errors highlighted below.</strong>
        {% if form.vars.errors|length > 0 %}
            <ul class="mb-0 mt-1 ps-3">
                {% for error in form.vars.errors %}<li>{{ error.message }}</li>{% endfor %}
            </ul>
        {% endif %}
    </div>
{% endif %}
<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-12">{{ form_row(form.label) }}</div>
            <div class="col-12">{{ form_row(form.streetLine1) }}</div>
            <div class="col-12">{{ form_row(form.streetLine2) }}</div>
            <div class="col-12 col-md-6">{{ form_row(form.city) }}</div>
            <div class="col-12 col-md-6">{{ form_row(form.stateOrRegion) }}</div>
            <div class="col-12 col-md-6">{{ form_row(form.postalCode) }}</div>
            <div class="col-12 col-md-6">{{ form_row(form.countryCode) }}</div>
            <div class="col-12">{{ form_row(form.additionalInfo) }}</div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-primary">{{ button_label|default('Save') }}</button>
            <a class="btn btn-outline-secondary" href="{{ path('app_user_show', {'id': app.user.id}) }}">Back to profile</a>
        </div>
    </div>
</div>
{{ form_end(form) }}
