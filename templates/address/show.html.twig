{% extends 'base.html.twig' %}

{% block title %}Address{% endblock %}

{% block body %}
    <h1>Address</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ address.id }}</td>
            </tr>
            <tr>
                <th>Label</th>
                <td>{{ address.label }}</td>
            </tr>
            <tr>
                <th>StreetLine1</th>
                <td>{{ address.streetLine1 }}</td>
            </tr>
            <tr>
                <th>StreetLine2</th>
                <td>{{ address.streetLine2 }}</td>
            </tr>
            <tr>
                <th>City</th>
                <td>{{ address.city }}</td>
            </tr>
            <tr>
                <th>StateOrRegion</th>
                <td>{{ address.stateOrRegion }}</td>
            </tr>
            <tr>
                <th>PostalCode</th>
                <td>{{ address.postalCode }}</td>
            </tr>
            <tr>
                <th>CountryCode</th>
                <td>{{ address.countryCode }}</td>
            </tr>
            <tr>
                <th>AdditionalInfo</th>
                <td>{{ address.additionalInfo }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_address_index') }}">back to list</a>

    <a href="{{ path('app_address_edit', {'id': address.id}) }}">edit</a>

    {{ include('address/_delete_form.html.twig') }}
{% endblock %}
